# Copy to .env.local (or edit .env.local in this repo — it is gitignored)
#
# This app’s hosted URL (project ref: znmqwqeknkvyxiwjcmyz):
#   https://znmqwqeknkvyxiwjcmyz.supabase.co
#
# Dashboard → Project Settings → API:
#   - Project URL → VITE_SUPABASE_URL
#   - anon public key → VITE_SUPABASE_ANON_KEY (public by design; protect data with RLS)
#
VITE_SUPABASE_URL=https://znmqwqeknkvyxiwjcmyz.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: skip the login screen while Google SSO is still a placeholder (dev / design review)
# VITE_LOGIN_SKIP_AUTH=true

# Workspace password for the login screen (default is Engineering if unset)
# VITE_APP_ACCESS_PASSWORD=Engineering

# Local Supabase (Docker): run `npm run supabase:start`, then `npm run supabase:status`
# and paste API URL + anon key from the output into .env.local instead of the lines above.
