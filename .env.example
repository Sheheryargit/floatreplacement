# Copy to .env.local (gitignored) and set your own values.
#
# Dashboard -> Project Settings -> API:
#   - Project URL -> VITE_SUPABASE_URL
#   - anon public key -> VITE_SUPABASE_ANON_KEY (public by design; protect data with RLS)
#
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: skip the login screen while Google SSO is still a placeholder (dev / design review)
# VITE_LOGIN_SKIP_AUTH=true

# Workspace password for the login screen (default is Engineering1 if unset)
# VITE_APP_ACCESS_PASSWORD=Engineering1

# Optional website placeholders (only if needed in your app logic later):
# VITE_APP_WEB_URL=https://your-app-domain.com
# VITE_API_WEBHOOK_URL=https://your-webhook-endpoint.example.com

# Local Supabase (Docker): use http://127.0.0.1:54321 + key from `npx supabase status` in .env.local instead.
